{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NormalizedPRContext",
  "type": "object",
  "required": [
    "pr_number",
    "base_sha",
    "head_sha",
    "pr_body_sections",
    "issue_summary",
    "changed_files",
    "diff_hunks",
    "codeowners_hits",
    "ci_status",
    "risk_tags"
  ],
  "properties": {
    "pr_number": {
      "type": "integer"
    },
    "base_sha": {
      "type": "string"
    },
    "head_sha": {
      "type": "string"
    },
    "pr_body_sections": {
      "type": "object"
    },
    "issue_summary": {
      "type": "object"
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "diff_hunks": {
      "type": "object"
    },
    "codeowners_hits": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "ci_status": {
      "type": "object"
    },
    "risk_tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
